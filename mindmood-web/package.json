{
  // ================================================================
  // package.json — Dependencias y scripts de MindMood Web
  // Scripts principales:
  //   dev     — Inicia servidor de desarrollo Vite
  //   build   — Compila para producción con Vite
  //   preview — Previsualiza la build de producción
  //
  // Dependencias clave:
  //   react / react-dom / react-router-dom — UI y enrutamiento
  //   @supabase/supabase-js — Backend y autenticación
  //   framer-motion — Animaciones declarativas
  //   recharts — Gráficos (pastel, barras)
  //   lucide-react — Iconos SVG
  //   date-fns — Formateo de fechas (locale ES/EN)
  //   @radix-ui/* — Componentes headless accesibles
  //   tailwindcss / @tailwindcss/vite — Estilos utilitarios
  //   vite / @vitejs/plugin-react — Bundler y compilador
  // ================================================================
  "name": "mindmood-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@supabase/supabase-js": "^2.104.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.46.1",
    "framer-motion": "^12.7.4",
    "lucide-react": "^0.510.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.6.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.1",
    "tailwindcss": "^4.1.4",
    "vite": "^6.3.2"
  }
}
